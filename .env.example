# Copy to .env and fill in your keys (never commit .env)

# Inference API (Vertex-style generateContent endpoint)
INFERENCE_API_KEY=your-inference-api-key-here
# URL and model are set in configurations/config.py via INFERENCE_API_URL and INFERENCE_API_MODEL
# Override here if needed:
# INFERENCE_API_URL=https://your-endpoint/v1/projects/.../models/{model}:generateContent
# INFERENCE_API_MODEL=gcp/google/gemini-2.5-flash-lite
# INFERENCE_API_TIMEOUT_S=180

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key-here
